age {\n    const typeKey: keyof VekterToPluginMessage = \"type\"\n    return isObject(data) && isVekterToPluginMessageType(data[typeKey])\n}\n","import type { Font } from \"./fonts\"\nimport type { FramerPluginAPI } from \"./framerAPI\"\nimport type { ConicGradient, LinearGradient, RadialGradient } from \"./gradients\"\nimport type { WithInvoke } from \"./invoke\"\nimport type {\n    AllTraits,\n    BorderRadius,\n    ControlAttributes,\n    HeightConstraint,\n    HeightLength,\n    NodeAttributeKey,\n    NodeId,\n    PercentageLength,\n    PixelLength,\n    Position,\n    TraitVariantData,\n    TraitVariantNode,\n    WidthConstraint,\n    WidthLength,\n    WithAspectRatioTrait,\n    WithBackgroundColorTrait,\n    WithBackgroundGradientTrait,\n    WithBackgroundImageTrait,\n    WithBorderRadiusTrait,\n    WithComponentInfoTrait,\n    WithControlAttributesTrait,\n    WithFontTrait,\n    WithIdTrait,\n    WithInlineTextStyleTrait,\n    WithLinkTrait,\n    WithLockedTrait,\n    WithNameTrait,\n    WithOpacityTrait,\n    WithPinsTrait,\n    WithPositionTrait,\n    WithReplicaInfoTrait,\n    WithRotationTrait,\n    WithSizeConstraintsTrait,\n    WithSizeTrait,\n    WithSVGTrait,\n    WithVisibleTrait,\n    WithWebPageInfoTrait,\n} from \"./traits\"\nimport type { ZoomIntoViewOptions } from \"./viewport\"\n\nimport { ImageAsset } from \"./assets\"\nimport { reviveAttributes, serializeAttributes } from \"./attributes\"\nimport { createFont } from \"./fonts\"\nimport { createGradient, isGradientData } from \"./gradients\"\nimport { withInvoke } from \"./invoke\"\nimport { TextStyle } from \"./styles\"\nimport { assert, isString, shouldBeNever } from \"./utils\"\n\nexport interface Rect {\n    x: number\n    y: number\n    width: number\n    height: number\n}\n\nconst createableNodes = [\"FrameNode\"] as const\nconst otherNodes = [\n    \"SVGNode\",\n    \"WebPageNode\",\n    \"ComponentNode\",\n    \"UnknownNode\",\n    \"ComponentInstanceNode\",\n    \"TextNode\",\n] as const\n\nexport type CreateNodeType = (typeof createableNodes)[number]\ntype OtherNodeType = (typeof otherNodes)[number]\nexport type PluginNodeClass = OtherNodeType | CreateNodeType\nexport type KnownNodeClass = Exclude<PluginNodeClass, \"UnknownNode\">\n\nexport type NodeWithAttribute<T extends NodeAttributeKey> = Extract<AnyNode, Record<T, unknown>>\n\nexport interface CommonNodeData extends WithIdTrait, WithReplicaInfoTrait {\n    __class: PluginNodeClass\n}\n\nexport abstract class NodeMethods implements WithIdTrait {\n    readonly id: NodeId\n    readonly #originalId: string | null\n\n    // We use `#` to make sure the api and data fields can not be observed when a user logs or loops\n    // over a node instance.\n    #api: FramerPluginAPI\n    #invokableApi: WithInvoke\n\n    constructor(data: Partial<SomeNodeData>, api: FramerPluginAPI) {\n        assert(isString(data.id), \"Node must have an id\")\n        this.id = data.id\n        this.#api = api\n        this.#originalId = data.originalId ?? null\n\n        assert(withInvoke(api))\n        this.#invokableApi = api\n    }\n\n    // Getters\n\n    get isReplica(): boolean {\n        return this.#originalId !== null\n    }\n\n    // Methods\n\n    remove(): Promise<void> {\n        return this.#api.removeNode(this.id)\n    }\n\n    select(): Promise<void> {\n        return this.#api.setSelection([this.id])\n    }\n\n    clone(): Promise<AnyNode | null> {\n        return this.#api.cloneNode(this.id)\n    }\n\n    setAttributes(update: Partial<AnyEditableAttributes>): Promise<AnyNode | null> {\n        return this.#api.setAttributes(this.id, update)\n    }\n\n    getRect(): Promise<Rect | null> {\n        return this.#api.getRect(this.id)\n    }\n\n    /** Pans and zooms the viewport to center the node. */\n    zoomIntoView(options?: ZoomIntoViewOptions): Promise<void> {\n        return this.#api.zoomIntoView([this.id], options)\n    }\n\n    // Iterators\n\n    getParent(): Promise<AnyNode | null> {\n        return this.#api.getParent(this.id)\n    }\n\n    getChildren(): Promise<CanvasNode[]> {\n        if (isUnknownNode(this)) return Promise.resolve([])\n        return this.#api.getChildren(this.id)\n    }\n\n    async getNodesWithType(type: \"FrameNode\"): Promise<FrameNode[]>\n    async getNodesWithType(type: \"TextNode\"): Promise<TextNode[]>\n    async getNodesWithType(type: \"SVGNode\"): Promise<SVGNode[]>\n    async getNodesWithType(type: \"ComponentInstanceNode\"): Promise<ComponentInstanceNode[]>\n    async getNodesWithType(type: \"WebPageNode\"): Promise<WebPageNode[]>\n    async getNodesWithType(type: \"ComponentNode\"): Promise<ComponentNode[]>\n    async getNodesWithType(type: KnownNodeClass): Promise<AnyNode[]> {\n        if (isUnknownNode(this)) return Promise.resolve([])\n        const nodeData = await this.#invokableApi.invoke(\"getNodesWithType\", this.id, type)\n        return nodeData.map(data => convertRawNodeDataToNode(data, this.#api))\n    }\n\n    async getNodesWithAttribute<T extends NodeAttributeKey, Node = NodeWithAttribute<T>>(\n        attribute: T\n    ): Promise<Node[]> {\n        if (isUnknownNode(this)) return Promise.resolve([])\n        const nodeData = await this.#invokableApi.invoke(\"getNodesWithAttribute\", this.id, attribute)\n        return nodeData.map(data => convertRawNodeDataToNode(data, this.#api) as Node)\n    }\n\n    async getNodesWithAttributeSet<T extends NodeAttributeKey, Node = NodeWithAttribute<T>>(\n        attribute: T\n    ): Promise<Node[]> {\n        if (isUnknownNode(this)) return Promise.resolve([])\n        const nodeData = await this.#invokableApi.invoke(\"getNodesWithAttributeSet\", this.id, attribute)\n        return nodeData.map(data => convertRawNodeDataToNode(data, this.#api) as Node)\n    }\n\n    async *walk(this: AnyNode): AsyncGenerator<AnyNode> {\n        yield this\n        if (isUnknownNode(this)) return\n\n        for (const child of await this.getChildren()) {\n            yield* child.walk()\