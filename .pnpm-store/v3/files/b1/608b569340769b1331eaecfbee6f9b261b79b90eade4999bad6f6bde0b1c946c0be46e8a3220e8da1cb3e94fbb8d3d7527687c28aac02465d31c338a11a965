pe: \"idle\" }\n\n    const dragPointerEventsTarget = document.body\n\n    const endDrag = (info: Pick<DragEndInfo, \"cancelled\">) => {\n        if (state.type === \"idle\") return\n\n        if (state.type === \"dragging\") {\n            void framer.invoke(\"onDragEnd\", { ...info, dragSessionId })\n        }\n\n        state = { type: \"idle\" }\n        dragCleanup()\n    }\n\n    const handlePointerChange = (event: PointerEvent) => {\n        if (state.type === \"idle\") return\n\n        const primaryButtonDown = event.buttons > 0 && Boolean(event.buttons & 1)\n\n        if (!primaryButtonDown) {\n            endDrag({ cancelled: false })\n            return\n        }\n\n        const { clientX, clientY } = event\n\n        if (state.type === \"pointerDown\") {\n            const deltaX = clientX - state.dragStart.mouse.x\n            const deltaY = clientY - state.dragStart.mouse.y\n            if (Math.abs(deltaX) < moveThreshold && Math.abs(deltaY) < moveThreshold) return\n\n            state = { type: \"dragging\", dragStart: state.dragStart }\n            void framer.invoke(\"onDragStart\", state.dragStart)\n            document.getSelection()?.empty()\n            pointerEvents.disableUntilMouseUp()\n        }\n\n        dragPointerEventsTarget.setPointerCapture(event.pointerId)\n        const mouse = { x: clientX, y: clientY }\n        void framer.invoke(\"onDrag\", { dragSessionId, mouse }).then(cursor => {\n            if (state.type === \"dragging\") document.body.style.cursor = cursor ?? \"\"\n        })\n    }\n\n    const handleKeyDown = (event: KeyboardEvent) => {\n        if (event.key === \"Escape\") {\n            endDrag({ cancelled: true })\n        }\n    }\n\n    const handleBlur = () => {\n        endDrag({ cancelled: true })\n    }\n\n    const handlePointerDown = (event: PointerEvent) => {\n        // Cancel any previous drag if needed\n        endDrag({ cancelled: true })\n\n        // Store the drag start info, actual drag only starts if the mouse moves a certain threshold\n        const clientRect = element.getBoundingClientRect()\n        const elementRect = {\n            x: clientRect.x,\n            y: clientRect.y,\n            width: clientRect.width,\n            height: clientRect.height,\n        }\n\n        let svgRect: Rect | undefined = undefined\n\n        const svgChildren = element.querySelectorAll(\"svg\")\n        if (svgChildren.length === 1) {\n            const svgElement = svgChildren.item(0)\n            const svgBounds = svgElement.getBoundingClientRect()\n            svgRect = { x: svgBounds.x, y: svgBounds.y, width: svgBounds.width, height: svgBounds.height }\n        }\n\n        const mouse = { x: event.clientX, y: event.clientY }\n        const dragStart: DragStartInfo = { dragSessionId, elementRect, svgRect, mouse }\n        state = { type: \"pointerDown\", dragStart }\n\n        void framer.invoke(\"setDragData\", dragSessionId, getDragData())\n\n        dragPointerEventsTarget.addEventListener(\"pointermove\", handlePointerChange, true)\n        dragPointerEventsTarget.addEventListener(\"pointerup\", handlePointerChange, true)\n        window.addEventListener(\"keydown\", handleKeyDown, true)\n        window.addEventListener(\"blur\", handleBlur)\n    }\n\n    const preload = () => {\n        const dragData = getDragData()\n        if (dragData.type === \"detachedComponentLayers\") {\n            void framer.invoke(\"preloadDetachedComponentLayers\", dragData.url)\n        }\n        if (dragData.type === \"image\") {\n            void framer.invoke(\"preloadImageUrlForInsertion\", dragData.image)\n        }\n        if (dragData.previewImage) {\n            void framer.invoke(\"preloadDragPreviewImage\", dragData.previewImage)\n        }\n    }\n\n    element.addEventListener(\"pointerdown\", handlePointerDown)\n    element.addEventListener(\"mouseenter\", preload)\n\n    function dragCleanup() {\n        document.body.style.cursor = originalBodyCursor\n\n        dragPointerEventsTarget.removeEventListener(\"pointermove\", handlePointerChange, true)\n        dragPointerEventsTarget.removeEventListener(\"pointerup\", handlePointerChange, true)\n        window.removeEventListener(\"keydown\", handleKeyDown, true)\n        window.removeEventListener(\"blur\", handleBlur)\n    }\n\n    return () => {\n        element.removeEventListener(\"pointerdown\", handlePointerDown)\n        element.removeEventListener(\"mouseenter\", preload)\n        endDrag({ cancelled: true })\n    }\n}\n","export class FramerPluginError extends Error {}\n","import type { ImageAssetData } from \"./assets\"\nimport type { CustomCode } from \"./customCode\"\nimport type { PluginMessageAPI } from \"./framerAPI\"\nimport type { SomeNodeData } from \"./nodes\"\nimport type { PublishInfo } from \"./publishInfo\"\nimport type { ColorStyleData, TextStyleData } from \"./styles\"\nimport type { Theme } from \"./theme\"\n\nimport { isObject, isString } from \"./utils\"\n\nexport type PluginMessageId = number\n\nexport type Mode =\n    | \"canvas\"\n    | \"default\" // Deprecated - will be removed before v1.0\n    | \"image\"\n    | \"editImage\"\n    | \"configureManagedCollection\"\n    | \"syncManagedCollection\"\n    | \"collection\"\n\nconst allModes: Record<Mode, true> = {\n    canvas: true,\n    default: true,\n    image: true,\n    editImage: true,\n    configureManagedCollection: true,\n    syncManagedCollection: true,\n    collection: true,\n}\n\nexport function isMode(value: unknown): value is Mode {\n    return isString(value) && value in allModes\n}\n\nexport interface PluginMethodResponse {\n    type: \"methodResponse\"\n    id: PluginMessageId\n    result: unknown\n    error: string | null\n}\n\nexport interface PluginMethodInvocation {\n    type: \"methodInvocation\"\n    methodName: keyof PluginMessageAPI\n    id: PluginMessageId\n    args: unknown[]\n}\n\nexport interface PluginSubscription {\n    type: \"subscribe\" | \"unsubscribe\"\n    topic: PluginSubscriptionTopic\n}\n\nexport interface PluginReadySignal {\n    type: \"pluginReadySignal\"\n    breakingChangesVersion: number\n}\n\nexport interface PluginReadyResponse {\n    type: \"pluginReadyResponse\"\n    mode: Mode\n    theme: Theme\n}\n\ninterface PluginSubscriptionBase {\n    type: \"subscriptionMessage\"\n    payload: unknown\n}\n\ninterface PluginSubscriptionPublishInfo extends PluginSubscriptionBase {\n    topic: \"publishInfo\"\n    payload: PublishInfo\n}\n\ninterface PluginSubscriptionSelection extends PluginSubscriptionBase {\n    topic: \"selection\"\n    payload: SomeNodeData[]\n}\n\ninterface PluginSubscriptionCanvasRoot extends PluginSubscriptionBase {\n    topic: \"canvasRoot\"\n    payload: SomeNodeData\n}\n\ninterface PluginSubscriptionImage extends PluginSubscriptionBase {\n    topic: \"image\"\n    payload: ImageAssetData | null\n}\n\ninterface PluginSubscriptionText extends PluginSubscriptionBase {\n    topic: \"text\"\n    payload: string | null\n}\n\ninterface PluginSubscriptionCustomHTML extends PluginSubscriptionBase {\n    topic: \"customCode\"\n    payload: CustomCode\n}\n\ninterface PluginSubscriptionTheme extends PluginSubscriptionBase {\n    topic: \"theme\"\n    payload: Theme\n}\n\ninterface PluginSubscriptionColorStyle extends PluginSubscriptionBase {\n    topic: \"colorStyles\"\n    payload: ColorStyleData[]\n}\n\ninterface PluginSubscriptionTextStyle extends PluginSubscriptionBase {\n    topic: \"textStyles\"\n    payload: TextStyleData[]\n}\n\n// TODO: Do we need to split PublishInfo into:\n// - data that changes when published (e.g., status, timestamp)\n// - data that changes when updating domains (e.g., url)\n// - data that changes when switching between pages (e.g., currentPageUrl)\n// We probably want separate events for all of these.\n// We might also want an \"optimization finished\" event.\n// https://github.com/framer/company/issues/29312\nexport type PluginSubscriptionEvent =\n    | PluginSubscription