entifier\")\n\n        this.componentIdentifier = rawData.componentIdentifier\n        this.insertURL = rawData.insertURL ?? null\n        this.componentName = rawData.componentName ?? null\n        this.name = rawData.name ?? null\n\n        Object.freeze(this)\n    }\n\n    override clone() {\n        return super.clone() as Promise<ComponentNode | null>\n    }\n\n    override setAttributes(update: Partial<EditableComponentNodeAttributes>) {\n        return super.setAttributes(update) as Promise<ComponentNode | null>\n    }\n}\n\nexport interface UnknownNodeData extends CommonNodeData {\n    __class: \"UnknownNode\"\n}\n\nexport class UnknownNode extends NodeMethods {\n    readonly __class: UnknownNodeData[\"__class\"] = \"UnknownNode\"\n\n    constructor(rawData: Partial<UnknownNodeData>, api: FramerPluginAPI) {\n        super(rawData, api)\n\n        Object.freeze(this)\n    }\n\n    override clone(): Promise<null> {\n        throw Error(\"Can not clone unknown node\")\n    }\n\n    override setAttributes(_update: unknown): Promise<AnyNode | null> {\n        throw Error(\"Can not set attributes on unknown node\")\n    }\n}\n\n// Figma uses the term SceneNode instead of CanvasRootNode, should we use the same name?\nexport type CanvasRootNode = WebPageNode | ComponentNode | UnknownNode\nexport type CanvasNode = FrameNode | TextNode | ComponentInstanceNode | SVGNode | UnknownNode\n\nexport type SomeNodeData =\n    | FrameNodeData\n    | TextNodeData\n    | ComponentInstanceNodeData\n    | SVGNodeData\n    | WebPageNodeData\n    | ComponentNodeData\n    | UnknownNodeData\n\nexport interface AnyNodeData extends Partial<AllTraits<TraitVariantData>>, WithReplicaInfoTrait {\n    __class: PluginNodeClass\n}\n\nexport interface AnyEditableAttributes\n    extends EditableFrameNodeAttributes,\n        EditableTextNodeAttributes,\n        EditableSVGNodeAttributes,\n        EditableComponentInstanceNodeAttributes,\n        EditableComponentNodeAttributes,\n        EditableWebPageNodeAttributes {}\n\nexport type AnyNode = CanvasNode | CanvasRootNode\n\nexport function convertRawNodeDataToNode(rawNodeData: SomeNodeData, api: FramerPluginAPI): AnyNode {\n    switch (rawNodeData.__class) {\n        case \"WebPageNode\":\n            return new WebPageNode(rawNodeData, api)\n        case \"ComponentNode\":\n            return new ComponentNode(rawNodeData, api)\n        case \"ComponentInstanceNode\":\n            return new ComponentInstanceNode(rawNodeData, api)\n        case \"FrameNode\":\n            return new FrameNode(rawNodeData, api)\n        case \"SVGNode\":\n            return new SVGNode(rawNodeData, api)\n        case \"TextNode\":\n            return new TextNode(rawNodeData, api)\n        case \"UnknownNode\":\n            return new UnknownNode(rawNodeData, api)\n        default:\n            shouldBeNever(rawNodeData)\n            return new UnknownNode(rawNodeData, api)\n    }\n}\n\nexport function convertEditableAttributesToNodeData(attributes: Partial<AnyEditableAttributes>): Partial<AnyNodeData> {\n    return serializeAttributes(attributes) as Partial<AnyNodeData>\n}\n\nexport function isFrameNode(node: unknown): node is FrameNode {\n    return node instanceof FrameNode\n}\n\nexport function isTextNode(node: unknown): node is TextNode {\n    return node instanceof TextNode\n}\n\nexport function isSVGNode(node: unknown): node is SVGNode {\n    return node instanceof SVGNode\n}\n\nexport function isComponentInstanceNode(node: unknown): node is ComponentInstanceNode {\n    return node instanceof ComponentInstanceNode\n}\n\nexport function isWebPageNode(node: unknown): node is WebPageNode {\n    return node instanceof WebPageNode\n}\n\nexport function isComponentNode(node: unknown): node is ComponentNode {\n    return node instanceof ComponentNode\n}\n\nexport function isUnknownNode(node: unknown): node is UnknownNode {\n    return node instanceof UnknownNode\n}\n\nexport function isCanvasNode(node: unknown): node is Canv