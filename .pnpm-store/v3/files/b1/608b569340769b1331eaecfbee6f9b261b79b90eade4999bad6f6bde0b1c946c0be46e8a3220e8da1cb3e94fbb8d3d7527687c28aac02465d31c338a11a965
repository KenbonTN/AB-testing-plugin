{"version":3,"sources":["../src/Draggable.tsx","../src/useMakeDraggable.ts","../src/invoke.ts","../src/utils.ts","../src/assets.ts","../src/fonts.ts","../src/gradients.ts","../src/styles.ts","../src/attributes.ts","../src/collections.ts","../src/dragging.ts","../src/errors.ts","../src/messages.ts","../src/nodes.ts","../src/theme.ts","../src/framerAPI.ts","../src/framer.ts","../src/traits.ts"],"sourcesContent":["import type { DragData } from \"./dragging\"\n\nimport React from \"react\"\nimport { useMakeDraggable } from \"./useMakeDraggable\"\nimport { isFunction, isObject } from \"./utils\"\n\ninterface DraggableProps {\n    data: DragData | (() => DragData)\n    children: React.ReactElement\n}\n\nexport const Draggable = React.forwardRef<HTMLElement, DraggableProps>(function Draggable(\n    { data, children, ...props },\n    forwardedRef\n) {\n    const ref = React.useRef<HTMLElement>(null)\n    useMakeDraggable(ref, data)\n\n    if (React.isValidElement(children)) {\n        const mergedProps: Record<string, unknown> = Object.assign({}, props)\n        if (isObject(children.props)) Object.assign(mergedProps, children.props)\n        mergedProps.ref = composeRefs(ref, forwardedRef, (children as { ref?: React.Ref<HTMLElement> }).ref)\n        return React.cloneElement(children, mergedProps)\n    }\n\n    if (React.Children.count(children) > 1) {\n        React.Children.only(children)\n    }\n\n    return null\n}) as React.FC<DraggableProps>\n\nconst currentKey: keyof React.MutableRefObject<unknown> = \"current\"\n\nfunction isMutableRefObject(\n    ref: React.Ref<HTMLElement> | undefined | null\n): ref is React.MutableRefObject<HTMLElement> {\n    return isObject(ref) && currentKey in ref\n}\n\nfunction composeRefs(...refs: (React.Ref<HTMLElement> | undefined | null)[]) {\n    return (element: HTMLElement) => {\n        for (const ref of refs) {\n            if (isFunction(ref)) {\n                ref(element)\n            } else if (isMutableRefObject(ref)) {\n                ref.current = element\n            }\n        }\n    }\n}\n","import type { RefObject } from \"react\"\nimport type React from \"react\"\nimport type { DragData } from \"./dragging\"\n\nimport { useCallback, useEffect, useRef } from \"react\"\nimport { framer } from \"./framer\"\nimport { isFunction } from \"./utils\"\n\nexport interface DraggableProps extends React.PropsWithChildren<React.ComponentPropsWithRef<\"div\">> {\n    data: DragData | (() => DragData)\n}\n\nexport function useMakeDraggable(ref: RefObject<HTMLElement>, data: DragData | (() => DragData)) {\n    const getDragData = useStableCallback(() => (isFunction(data) ? data() : data))\n\n    useEffect(() => {\n        const element = ref.current\n        if (!(element instanceof HTMLElement)) return\n        return framer.makeDraggable(element, getDragData)\n    }, [getDragData])\n}\n\nfunction useStableCallback<Args extends unknown[], Result>(callback: (...args: Args) => Result) {\n    const latest = useRef(callback)\n    latest.current = callback\n    return useCallback((...args: Args) => latest.current(...args), [])\n}\n","import type { PluginMessageAPI } from \"./framerAPI\"\n\nexport interface WithInvoke {\n    invoke<\n        Name extends keyof PluginMessageAPI,\n        Args extends Parameters<PluginMessageAPI[Name]>,\n        Return extends ReturnType<PluginMessageAPI[Name]>,\n    >(\n        methodName: Name,\n        ...args: Args\n    ): Return\n}\n\nconst invokeKey: keyof WithInvoke = \"invoke\"\n\nexport function withInvoke<T extends object>(value: T): value is T & WithInvoke {\n    return invokeKey in value\n}\n","export function isNull(value: unknown): value is null {\n    return value === null\n}\n\nexport function isBoolean(value: unknown): value is boolean {\n    return value === true || value === false\n}\n\nexport function isString(value: unknown): value is string {\n    return typeof value === \"string\"\n}\n\nexport function isNumber(value: unknown): value is number {\n    return typeof value === \"number\" && Number.isFinite(value)\n}\n\nexport function isFunction(value: unknown): value is (...parameters: unknown[]) => unknown {\n    return typeof value === \"function\"\n}\n\nexport function isObject(value: unknown): value is Record<string, unknown> {\n    return typeof value === \"object\" && value !== null && !Array.isArray(value)\n}\n\nexport function isArray(value: unknown): value is unknown[] {\n    return Array.isArray(value)\n}\n\nexport function shouldBeNever(_: never) {}\n\nexport function assertNever(x: never, error?: unknown): never {\n    throw error || new Error((x as unknown) ? `Unexpected value: ${x}` : \"Application entered invalid state\")\n}\n\nexport function assert(condition: unknown, ...msg: unknown[]): asserts condition {\n    if (condition) return\n\n    const e = Error(\"Assertion Error\" + (msg.length > 0 ? \": \" + msg.join(\" \") : \"\"))\n    // Hack the stack so the assert call itself disappears. Works in jest and in chrome.\n    if (e.stack) {\n        try {\n            const lines = e.stack.split(\"\\n\")\n            if (lines[1]?.includes(\"assert\")) {\n                lines.splice(1, 1)\n                e.stack = lines.join(\"\\n\")\n            } else if (lines[0]?.includes(\"assert\")) {\n                lines.splice(0, 1)\n                e.stack = lines.join(\"\\n\")\n            }\n        } catch {\n            // nothing\n        }\n    }\n    throw e\n}\n","import type { FramerAPI } from \"./framerAPI\"\nimport type { WithInvoke } from \"./invoke\"\nimport type { Prettify } from \"./Prettify\"\n\nimport { withInvoke } from \"./invoke\"\nimport { assert, isObject, isString } from \"./utils\"\n\nexport type AssetId = string\n\nexport interface AssetIdentifier {\n    id: string\n}\n\ninterface WithOptionalName {\n    name?: string\n}\n\ninterface AssetData extends WithOptionalName {\n    /** Something that can be rendered within the iFrame. Always the original size of the image */\n    url: string\n}\n\ninterface FileAssetDataFields extends AssetData {\n    extension: string | null\n}\n\nconst fileAssetDiscriminator = \"FileAsset\" as const\n\nexport interface FileAssetData extends AssetIdentifier, FileAssetDataFields {\n    __class: typeof fileAssetDiscriminator\n}\n\nconst fileAssetClassKey: keyof FileAssetData = \"__class\"\n\nexport function isFileAssetData(data: unknown): data is FileAssetData {\n    if (!isObject(data)) return false\n\n    return data[fileAssetClassKey] === fileAssetDiscriminator\n}\n\nexport class FileAsset implements AssetIdentifier, FileAssetDataFields {\n    readonly id: AssetId\n    readonly url: string\n    readonly extension: string | null\n\n    constructor(data: FileAssetData) {\n        this.url = data.url\n        this.id = data.id\n        this.extension = data.extension\n    }\n}\n\nexport function isFileAsset(value: unknown): value is FileAsset {\n    return value instanceof FileAsset\n}\n\ninterface ImageDataFields extends AssetData {\n    /**\n     * Thumbnail URL of the image.\n     */\n    thumbnailUrl: string\n    /**\n     * Optional Alt Text of the image.\n     */\n    altText?: string\n}\n\nconst imageAssetDiscriminator = \"ImageAsset\" as const\n\nexport interface ImageAssetData extends AssetIdentifier, ImageDataFields {\n    __class: typeof imageAssetDiscriminator\n}\n\nconst imageAssetClassKey: keyof ImageAssetData = \"__class\"\n\nexport function isImageAssetData(data: unknown): data is ImageAssetData {\n    if (!isObject(data)) return false\n\n    return data[imageAssetClassKey] === imageAssetDiscriminator\n}\n\ninterface Size {\n    width: number\n    height: number\n}\n\nexport class ImageAsset implements ImageDataFields, AssetIdentifier {\n    readonly id: AssetId\n    readonly url: string\n    readonly thumbnailUrl: string\n    readonly altText: string | undefined\n\n    #imageData: BytesData | undefined\n\n    #api: WithInvoke & FramerAPI\n\n    constructor(data: ImageAssetData, api: FramerAPI) {\n        assert(withInvoke(api))\n        this.#api = api\n\n        this.url = data.url\n        this.id = data.id\n        this.thumbnailUrl = data.thumbnailUrl\n        this.altText = data.altText\n    }\n\n    cloneWithAttributes({ altText }: Prettify<Partial<Pick<ImageAssetData, \"altText\">>>) {\n        return new ImageAsset(\n            {\n                __class: \"ImageAsset\",\n                id: this.id,\n                url: this.url,\n                thumbnailUrl: this.thumbnailUrl,\n                altText: altText !== undefined ? altText : this.altText,\n            },\n            this.#api\n        )\n    }\n\n    async measure(): Promise<Size> {\n        return measureImage(this.url)\n    }\n\n    /**\n     * Get the data such as the bytes of the image.\n     * The bytes can be used to manipulate the pixels of the image.\n     */\n    async getData(): Promise<BytesData> {\n        if (\n            this.#imageData &&\n            // When data is transfered over postMessage (instead of the structured clone, which is default)\n            // The array buffer becomes empty on the sending side.\n            // In these cases we need to load the bytes again.\n            this.#imageData.bytes.length > 0\n        ) {\n            return this.#imageData\n        }\n\n        const data = await this.#api.invoke(\"getImageData\", { id: this.id })\n\n        if (!data) {\n            throw new Error(\"Failed to load image data\")\n        }\n\n        this.#imageData = data\n\n        return data\n    }\n\n    async loadBitmap() {\n        const { mimeType, bytes } = await this.getData()\n        const blob = new Blob([bytes], { type: mimeType })\n        return createImageBitmap(blob)\n    }\n\n    async loadImage(): Promise<HTMLImageElement> {\n        const data = await this.getData()\n        const url = URL.createObjectURL(new Blob([data.bytes]))\n\n        return new Promise<HTMLImageElement>((resolve, reject) => {\n            const img = new Image()\n            img.onload = () => resolve(img)\n            img.onerror = () => reject()\n            img.src = url\n        })\n    }\n}\n\nexport function isImageAsset(value: unknown): value is ImageAsset {\n    return value instanceof ImageAsset\n}\n\nexport type AssetInput = string | File | BytesData\n\nexport interface NamedImageAssetInput extends ImageData {\n    image: AssetInput\n}\n\nexport interface NamedFileAssetInput extends WithOptionalName {\n    file: AssetInput\n}\n\ninterface AssetURLDataTransfer {\n    type: \"url\"\n    url: string\n}\n\nexport interface BytesData {\n    bytes: Uint8Array\n    mimeType: string\n}\n\ntype BytesDataTransfer = BytesData & { type: \"bytes\" }\n\nexport interface ImageData extends WithOptionalName {\n    altText?: string\n}\n\nexport type AssetDataTransfer = AssetURLDataTransfer | BytesDataTransfer\nexport type NamedImageTransfer = AssetDataTransfer & ImageData\nexport type NamedAssetTransfer = AssetDataTransfer & WithOptionalName\n\nexport interface SVGData extends WithOptionalName {\n    svg: string\n}\n\nexport function getTransferable(data: AssetDataTransfer): Transferable[] {\n    if (data.type === \"bytes\") {\n        return [data.bytes.buffer]\n    }\n\n    return []\n}\n\nfunction isBytesData(value: unknown): value is BytesData {\n    if (!isObject(value)) return false\n\n    const bytesKey: keyof BytesData = \"bytes\"\n    const mimeTypeKey: keyof BytesData = \"mimeType\"\n\n    if (!(bytesKey in value)) return false\n    if (!(mimeTypeKey in value)) return false\n\n    if (!(value[bytesKey] instanceof Uint8Array)) return false\n    if (!isString(value[mimeTypeKey])) return false\n\n    return true\n}\n\nexport async function createImageTransferFromInput(input: NamedImageAssetInput | File): Promise<NamedImageTransfer> {\n    if (input instanceof File) {\n        return getAssetDataFromFile(input)\n    }\n\n    const assetData = await createAssetTransferFromAssetInput(input.image)\n\n    return {\n        name: input.name,\n        altText: input.altText,\n        ...assetData,\n    }\n}\n\nexport async function createFileTransferFromInput(input: NamedFileAssetInput | File): Promise<NamedAssetTransfer> {\n    if (input instanceof File) {\n        return getAssetDataFromFile(input)\n    }\n\n    const assetData = await createAssetTransferFromAssetInput(input.file)\n\n    return {\n        name: input.name,\n        ...assetData,\n    }\n}\n\nasync function createAssetTransferFromAssetInput(input: AssetInput): Promise<AssetDataTransfer> {\n    if (input instanceof File) {\n        return getAssetDataFromFile(input)\n    }\n\n    if (isBytesData(input)) {\n        return {\n            type: \"bytes\",\n            mimeType: input.mimeType,\n            bytes: input.bytes,\n        }\n    }\n\n    return {\n        type: \"url\",\n        url: input,\n    }\n}\n\nexport function createNamedAssetDataTransferFromInput(\n    input: readonly NamedImageAssetInput[]\n): Promise<NamedImageTransfer[]> {\n    return Promise.all(input.map(createImageTransferFromInput))\n}\n\ntype ImageMimeType = `image/${string}`\nexport function assertIsImageMimeType(mimeType: string): asserts mimeType is ImageMimeType {\n    if (!mimeType.startsWith(\"image/\")) {\n        throw new Error(`Unsupported mime type: ${mimeType}`)\n    }\n}\n\n/**\n *  Returns the bytes bytes and mime type of a file from a given File object\n */\nexport async function getAssetDataFromFile(file: File): Promise<AssetDataTransfer & WithOptionalName> {\n    return new Promise((resolve, reject) => {\n        const reader = new FileReader()\n        reader.onload = event => {\n            const type = file.type\n\n            const arrayBuffer = event.target?.result\n            if (!arrayBuffer || !(arrayBuffer instanceof ArrayBuffer)) {\n                reject(new Error(\"Failed to read file, arrayBuffer is null\"))\n                return\n            }\n\n            const bytes = new Uint8Array(arrayBuffer)\n\n            resolve({ bytes, mimeType: type, type: \"bytes\", name: file.name })\n        }\n        reader.onerror = error => {\n            reject(error)\n        }\n        reader.readAsArrayBuffer(file)\n    })\n}\n\nexport async function measureImage(input: File | string): Promise<Size> {\n    const isFileInput = input instanceof File\n    const src = isFileInput ? URL.createObjectURL(input) : input\n\n    const img = new Image()\n    img.crossOrigin = \"anonymous\"\n    img.src = src\n\n    await img.decode().finally(() => {\n        if (isFileInput) URL.revokeObjectURL(src)\n    })\n\n    return {\n        height: img.height,\n        width: img.width,\n    }\n}\n","import type { Prettify } from \"./Prettify\"\n\nimport { isNumber, isObject, isString } from \"./utils\"\n\ntype FontSelector = string\n\nexport interface FontData {\n    __class: \"Font\"\n    selector: FontSelector\n    family: string\n    weight: FontWeight | null\n    style: FontStyle | null\n}\n\nconst fontClassDiscriminator: FontData[\"__class\"] = \"Font\"\nexport function isFontData(value: unknown): value is FontData {\n    return isObject(value) && value.__class === fontClassDiscriminator\n}\n\nexport type FontAttributes = Prettify<\n    Partial<{\n        weight: FontWeight\n        style: FontStyle\n    }>\n>\n\nconst fontStyles = [\"normal\", \"italic\"] as const\nexport type FontStyle = (typeof fontStyles)[number]\n\nconst fontWeights = [100, 200, 300, 400, 500, 600, 700, 800, 900] as const\n/**\n * Boldness as an absolute value.\n *\n *  These values are usually associated with the following names:\n * - `100` - Thin\n * - `200` - Extra Light (Ultra Light)\n * - `300` - Light\n * - `400` - Normal\n * - `500` - Medium\n * - `600` - Semi Bold (Demi Bold)\n * - `700` - Bold\n * - `800` - Extra Bold\n * - `900` - Black (Heavy)\n * */\nexport type FontWeight = (typeof fontWeights)[number]\n\nexport function isFontWeight(value: unknown): value is FontWeight {\n    if (!isNumber(value)) return false\n\n    switch (value) {\n        case 100:\n        case 200:\n        case 300:\n        case 400:\n        case 500:\n        case 600:\n        case 700:\n        case 800:\n        case 900:\n            return true\n        default:\n            return false\n    }\n}\n\nexport function isFontStyle(value: unknown): value is FontStyle {\n    if (!isString(value)) return false\n\n    switch (value) {\n        case \"normal\":\n        case \"italic\":\n            return true\n        default:\n            return false\n    }\n}\n\nexport function isFont(value: unknown): value is Font {\n    if (!isObject(value)) return false\n    return isString(value.family) && isString(value.selector) && isFontWeight(value.weight) && isFontStyle(value.style)\n}\n\nexport class Font {\n    /** An identifier used internally for differentiating fonts. */\n    readonly selector: string\n    /** Name of the family the font belongs to. */\n    readonly family: string\n    /**\n     * Specifies how thin or bold the font appears.\n     *\n     * Note: This will be `null` for custom fonts since their weight isn't\n     * calculated.\n     * */\n    readonly weight: FontWeight | null\n    /**\n     * Specifies if the font is normal or _italic_.\n     *\n     * Note: This will be `null` for custom fonts since their weight isn't\n     * calculated.\n     * */\n    readonly style: FontStyle | null\n\n    constructor(data: FontData) {\n        this.selector = data.selector\n        this.family = data.family\n        this.weight = data.weight\n        this.style = data.style\n    }\n}\n\nconst fontInstanceCache = new Map<FontSelector, Font>()\n\n/**\n * Instantiate a new instance of `Font`. If it has been created before, reuse a\n * cached instance to ensure comparison equality.\n * */\nexport function createFont(fontData: FontData): Font {\n    const existingFont = fontInstanceCache.get(fontData.selector)\n    if (existingFont) return existingFont\n\n    const font = new Font(fontData)\n    fontInstanceCache.set(fontData.selector, font)\n\n    return font\n}\n\nexport function toFontData(font: Font): FontData {\n    return {\n        __class: \"Font\",\n        selector: font.selector,\n        family: font.family,\n        weight: font.weight,\n        style: font.style,\n    }\n}\n","import type { PercentageLength } from \"./traits\"\n\nimport { assertNever, isObject } from \"./utils\"\n\nexport interface ColorStop {\n    /** CSS color */\n    color: string\n    /** 0-1 */\n    position: number\n}\n\ninterface LinearGradientOptions {\n    /** 0-360 */\n    angle: number\n    /** Color stops with position */\n    stops: readonly ColorStop[]\n}\n\nconst classKey = \"__class\" as const\nconst linearGradientClassDiscriminator = \"LinearGradient\" as const\nconst radialGradientClassDiscriminator = \"RadialGradient\" as const\nconst conicGradientClassDiscriminator = \"ConicGradient\" as const\n\nexport type Gradient = LinearGradient | RadialGradient | ConicGradient\nexport type GradientData = LinearGradientData | RadialGradientData | ConicGradientData\n\nexport function isGradientData(data: unknown): data is GradientData {\n    if (!isObject(data)) return false\n    switch (data[classKey]) {\n        case linearGradientClassDiscriminator:\n        case radialGradientClassDiscriminator:\n        case conicGradientClassDiscriminator:\n            return true\n        default:\n            return false\n    }\n}\n\nexport function isGradient(value: unknown): value is Gradient {\n    return value instanceof LinearGradient || value instanceof RadialGradient || value instanceof ConicGradient\n}\n\nexport function toGradientData(value: Gradient): GradientData {\n    if (value instanceof LinearGradient) {\n        return {\n            __class: linearGradientClassDiscriminator,\n            angle: value.angle,\n            stops: value.stops,\n        }\n    }\n    if (value instanceof RadialGradient) {\n        return {\n            __class: radialGradientClassDiscriminator,\n            width: value.width,\n            height: value.height,\n            x: value.x,\n            y: value.y,\n            stops: value.stops,\n        }\n    }\n    if (value instanceof ConicGradient) {\n        return {\n            __class: conicGradientClassDiscriminator,\n            angle: value.angle,\n            x: value.x,\n            y: value.y,\n            stops: value.stops,\n        }\n    }\n    assertNever(value)\n}\n\nexport function createGradient(data: GradientData): Gradient {\n    const classDiscriminator = data[classKey]\n    switch (classDiscriminator) {\n        case linearGradientClassDiscriminator:\n            return new LinearGradient(data)\n        case radialGradientClassDiscriminator:\n            return new RadialGradient(data)\n        case conicGradientClassDiscriminator:\n            return new ConicGradient(data)\n        default:\n            assertNever(data)\n    }\n}\n\nexport interface LinearGradientData extends LinearGradientOptions {\n    __class: typeof linearGradientClassDiscriminator\n}\n\nexport class LinearGradient implements LinearGradientOptions {\n    readonly angle: number\n    readonly stops: readonly ColorStop[]\n\n    constructor(options: LinearGradientOptions) {\n        this.angle = options.angle\n        this.stops = options.stops\n        Object.freeze(this)\n    }\n\n    cloneWithAttributes(attributes: Partial<LinearGradientOptions>): LinearGradient {\n        return new LinearGradient({\n            angle: attributes.angle ?? this.angle,\n            stops: attributes.stops ?? this.stops,\n        })\n    }\n\n    toCSS(): string {\n        const cssColorStops = this.stops.map(stop => `${stop.color} ${stop.position * 100}%`).join(\", \")\n        return `linear-gradient(${this.angle}deg, ${cssColorStops})`\n    }\n}\n\ninterface RadialGradientOptions {\n    /** Relative width */\n    width: PercentageLength\n    /** Relative height */\n    height: PercentageLength\n    /** Relative horizontal position */\n    x: PercentageLength\n    /** Relative vertical position */\n    y: PercentageLength\n    /** Color stops with position */\n    stops: readonly ColorStop[]\n}\n\nexport interface RadialGradientData extends RadialGradientOptions {\n    __class: typeof radialGradientClassDiscriminator\n}\n\nexport class RadialGradient implements RadialGradientOptions {\n    readonly width: PercentageLength\n    readonly height: PercentageLength\n    readonly x: PercentageLength\n    readonly y: PercentageLength\n    readonly stops: readonly ColorStop[]\n\n    constructor(options: RadialGradientOptions) {\n        this.width = options.width\n        this.height = options.height\n        this.x = options.x\n        this.y = options.y\n        this.stops = options.stops\n        Object.freeze(this)\n    }\n\n    cloneWithAttributes(attributes: Partial<RadialGradientOptions>): RadialGradient {\n        return new RadialGradient({\n            width: attributes.width ?? this.width,\n            height: attributes.height ?? this.height,\n            x: attributes.x ?? this.x,\n            y: attributes.y ?? this.y,\n            stops: attributes.stops ?? this.stops,\n        })\n    }\n\n    toCSS(): string {\n        // When both gradient stops are at 100% the gradient is a circle. This however is not\n        // supported by Safari, so we need to make sure that one of the stops is not at 100%. We do\n        // this by setting the stop before the last stop to slightly less than 100%.\n        const cssStops = this.stops\n            .map((stop, index) => {\n                const nextStop = this.stops[index + 1]\n                const position =\n                    stop.position === 1 && nextStop?.position === 1 ? stop.position - 0.0001 : stop.position\n                return `${stop.color} ${position * 100}%`\n            })\n            .join(\", \")\n        return `radial-gradient(${this.width} ${this.height} at ${this.x} ${this.y}, ${cssStops})`\n    }\n}\n\ninterface ConicGradientOptions {\n    /** 0-360 */\n    angle: number\n    /** Relative horizontal position */\n    x: PercentageLength\n    /** Relative vertical position */\n    y: PercentageLength\n    /** Color stops with position */\n    stops: readonly ColorStop[]\n}\n\nexport interface ConicGradientData extends ConicGradientOptions {\n    __class: typeof conicGradientClassDiscriminator\n}\n\nexport class ConicGradient implements ConicGradientOptions {\n    readonly angle: number\n    readonly x: PercentageLength\n    readonly y: PercentageLength\n    readonly stops: readonly ColorStop[]\n\n    constructor(options: ConicGradientOptions) {\n        this.angle = options.angle\n        this.x = options.x\n        this.y = options.y\n        this.stops = options.stops\n        Object.freeze(this)\n    }\n\n    cloneWithAttributes(attributes: Partial<ConicGradientOptions>): ConicGradient {\n        return new ConicGradient({\n            angle: attributes.angle ?? this.angle,\n            x: attributes.x ?? this.x,\n            y: attributes.y ?? this.y,\n            stops: attributes.stops ?? this.stops,\n        })\n    }\n\n    toCSS(): string {\n        const cssStops = this.stops.map(stop => `${stop.color} ${stop.position * 360}deg`).join(\", \")\n        return `conic-gradient(from ${this.angle}deg at ${this.x} ${this.y}, ${cssStops})`\n    }\n}\n","import type { CSSPercentageValue, CSSPixelValue, CSSRelativeValue } from \"./css\"\nimport type { FontData } from \"./fonts\"\nimport type { FramerAPI } from \"./framerAPI\"\nimport type { WithInvoke } from \"./invoke\"\nimport type { Prettify } from \"./Prettify\"\nimport type { TextAlignment, TextDecoration, TextTransform } from \"./text\"\nimport type { NodeId } from \"./traits\"\n\nimport { Font, toFontData } from \"./fonts\"\nimport { withInvoke } from \"./invoke\"\nimport { assert, isObject, isString } from \"./utils\"\n\nexport interface ColorStyleData {\n    id: NodeId\n    name: string\n    light: string\n    dark: string | null\n}\n\nexport type ColorStyleAttributes = Prettify<Partial<Omit<ColorStyleData, \"id\">>>\n\nexport class ColorStyle {\n    readonly id: NodeId\n    readonly name: string\n    /** Color used for the default or light theme in RGBA format, e.g `rgba(242, 59, 57, 1)` */\n    readonly light: string\n    /** Optional color used for the dark theme in RGBA format, e.g `rgba(242, 59, 57, 1)` */\n    readonly dark: string | null\n\n    #api: WithInvoke & FramerAPI\n\n    constructor(data: ColorStyleData, api: FramerAPI) {\n        assert(isString(data.id), \"Style must have an id\")\n\n        this.id = data.id\n        this.name = data.name\n        this.light = data.light\n        this.dark = data.dark\n\n        assert(withInvoke(api))\n        this.#api = api\n    }\n\n    /** Set the attributes of a color style. */\n    async setAttributes(update: ColorStyleAttributes): Promise<ColorStyle | null> {\n        const colorStyleData = await this.#api.invoke(\"setColorStyleAttributes\", this.id, update)\n        if (!colorStyleData) return null\n\n        return new ColorStyle(colorStyleData, this.#api)\n    }\n\n    /** Get plugin data for this color style by key. */\n    async getPluginData(key: string): Promise<string | null> {\n        return this.#api.invoke(\"getPluginDataForNode\", this.id, key)\n    }\n\n    /** Set plugin data on this color style by key. */\n    async setPluginData(key: string, value: string | null): Promise<void> {\n        return this.#api.invoke(\"setPluginDataForNode\", this.id, key, value)\n    }\n\n    /** Get all plugin data keys for this color style. */\n    async getPluginDataKeys() {\n        return this.#api.invoke(\"getPluginDataKeysForNode\", this.id)\n    }\n\n    /** Deletes the color style from the project. */\n    async remove(): Promise<void> {\n        return this.#api.invoke(\"removeColorStyle\", this.id)\n    }\n}\n\n// These are the same as rich text tags in `WithRichTextTag` trait in Vekter.\nexport type TextStyleTag = \"h1\" | \"h2\" | \"h3\" | \"h4\" | \"h5\" | \"h6\" | \"p\"\n\nexport interface TextStyleBreakpointData {\n    /**\n     * How big does the window width need to be for this breakpoint's styles to\n     * take affect.\n     *\n     * This must be unique for each breakpoint.\n     * */\n    minWidth: number\n    /** Size of the text at this breakpoint. */\n    fontSize: CSSPixelValue\n    /** Size of the space between each letter at this breakpoint. */\n    letterSpacing: CSSPixelValue | CSSRelativeValue\n    /** Size of the space between each line of text at this breakpoint. */\n    lineHeight: CSSPixelValue | CSSRelativeValue | CSSPercentageValue\n    /** Size of the space between each paragraph at this breakpoint. */\n    paragraphSpacing: number\n}\n\n// Ensure `minWidth` is the only required attribute and everything else is optional.\nexport type TextStyleBreakpointAttributes = Prettify<\n    Partial<TextStyleBreakpointData> & Pick<TextStyleBreakpointData, \"minWidth\">\n>\n\nexport type TextStyleBreakpoint = Prettify<TextStyleBreakpointData>\n\nconst textStyleDiscriminator = \"TextStyle\" as const\n\nexport interface TextStyleData extends TextStyleBreakpointData {\n    __class: typeof textStyleDiscriminator\n    id: NodeId\n    name: string\n    tag: TextStyleTag\n    color: string\n    font: FontData\n    boldFont: FontData | null\n    italicFont: FontData | null\n    boldItalicFont: FontData | null\n    transform: TextTransform\n    alignment: TextAlignment\n    decoration: TextDecoration\n    balance: boolean\n    breakpoints: TextStyleBreakpointData[]\n}\n\nconst textStyleClassKey: keyof TextStyleData = \"__class\"\n\nexport function isTextStyleData(data: unknown): data is TextStyleData {\n    if (!isObject(data)) return false\n\n    return data[textStyleClassKey] === textStyleDiscriminator\n}\n\nexport type TextStyleAttributes = Prettify<\n    Partial<\n        Omit<TextStyleData, \"id\" | \"font\" | \"boldFont\" | \"italicFont\" | \"boldItalicFont\" | \"breakpoints\"> & {\n            // Ensure font and all font variants are of type `Font` and not `FontData`.\n            font: Font\n            boldFont: Font | null\n            italicFont: Font | null\n            boldItalicFont: Font | null\n            // Ensure `breakpoints` is of type `TextStyleBreakpointAttributes` and not `TextStyleBreakpointData`\n            breakpoints: TextStyleBreakpointAttributes[]\n        }\n    >\n>\n\nexport class TextStyle {\n    readonly id: NodeId\n    readonly name: string\n    /** HTML tag that the style will use. */\n    readonly tag: TextStyleTag\n\n    /**\n     * Base font of the text.\n     *\n     * Setting this will automatically update `boldFont`, `italicFont` or\n     * `boldItalicFont` with the appropriate variants if they are not already\n     * specified.\n     * */\n    readonly font: Font\n    /**\n     * Font to use for bold text.\n     *\n     * Note: This must have the same family name as the base `font` attribute.\n     * */\n    readonly boldFont: Font | null\n    /**\n     * Font to use for italic text.\n     *\n     * Note: This must be the same family name as the base `font` attribute.\n     * */\n    readonly italicFont: Font | null\n    /**\n     * Font to use for bold italic text.\n     *\n     * Note: This must have the same family name as the base `font` attribute.\n     * */\n    readonly boldItalicFont: Font | null\n    /** Color of the text in RGBA format for all breakpoints, e.g `rgba(242, 59, 57, 1)` */\n    readonly color: string\n    /** Specifies how to capitalize the text for all breakpoints. */\n    readonly transform: TextTransform\n    /** Specifies the horizontal direction of the text for all breakpoints. */\n    readonly alignment: TextAlignment\n    /** Appearance of any decorative lines on the text for all breakpoints. */\n    readonly decoration: TextDecoration\n    /** When enabled, use a text wrap method that tries to balance the number of characters on each line for legibility. */\n    readonly balance: boolean\n    /** A list of style overrides that take affect at specific window widths. Breakpoints are automatically sorted by `minWidth` from largest to smallest. */\n    readonly breakpoints: TextStyleBreakpoint[]\n\n    /**\n     * How big does the window width need to be for primary breakpoint styles to\n     * take affect.\n     *\n     * Note: This is ignored if the text style has no breakpoints.\n     * */\n    readonly minWidth: number\n    /**\n     * Size of the text of the primary breakpoint.\n     *\n     * Note: This is used by default when there are no breakpoints.\n     * */\n    readonly fontSize: CSSPixelValue\n    /**\n     * Size of the space between each letter for the primary breakpoint.\n     *\n     * Note: This is used by default when there are no breakpoints.\n     * */\n    readonly letterSpacing: CSSPixelValue | CSSRelativeValue\n    /**\n     * Size of the space between each line of text for the primary breakpoint.\n     *\n     * Note: This is used by default when there are no breakpoints.\n     * */\n    readonly lineHeight: CSSPixelValue | CSSRelativeValue | CSSPercentageValue\n    /**\n     * Size of the space between each paragraph for the primary breakpoint.\n     *\n     * Note: This is used by default when there are no breakpoints.\n     * */\n    readonly paragraphSpacing: number\n\n    #api: WithInvoke & FramerAPI\n\n    constructor(data: TextStyleData, api: FramerAPI) {\n        assert(isString(data.id), \"Style must have an id\")\n\n        this.id = data.id\n        this.name = data.name\n        this.tag = data.tag\n\n        this.font = new Font(data.font)\n        this.boldFont = data.boldFont ? new Font(data.boldFont) : null\n        this.italicFont = data.italicFont ? new Font(data.italicFont) : null\n        this.boldItalicFont = data.boldItalicFont ? new Font(data.boldItalicFont) : null\n        this.color = data.color\n        this.transform = data.transform\n        this.alignment = data.alignment\n        this.decoration = data.decoration\n        this.balance = data.balance\n        this.breakpoints = data.breakpoints\n\n        this.minWidth = data.minWidth\n        this.fontSize = data.fontSize\n        this.letterSpacing = data.letterSpacing\n        this.lineHeight = data.lineHeight\n        this.paragraphSpacing = data.paragraphSpacing\n\n        assert(withInvoke(api))\n        this.#api = api\n    }\n\n    /**\n     * Set the attributes of the text style.\n     *\n     * @throws If the number of breakpoints is bigger than the limit of 4.\n     * @throws If any of the font families used for `boldFont`, `italicFont and\n     * `boldItalicFont` do not match the family of `font`.\n     * */\n    async setAttributes(update: TextStyleAttributes): Promise<TextStyle | null> {\n        const textStyleData = await this.#api.invoke(\"setTextStyleAttributes\", this.id, update)\n        if (!textStyleData) return null\n\n        return new TextStyle(textStyleData, this.#api)\n    }\n\n    /** Get plugin data for this text style by key. */\n    async getPluginData(key: string): Promise<string | null> {\n        return this.#api.invoke(\"getPluginDataForNode\", this.id, key)\n    }\n\n    /** Set plugin data on this text style by key. */\n    async setPluginData(key: string, value: string | null): Promise<void> {\n        return this.#api.invoke(\"setPluginDataForNode\", this.id, key, value)\n    }\n\n    /** Get all plugin data keys for this text style. */\n    async getPluginDataKeys() {\n        return this.#api.invoke(\"getPluginDataKeysForNode\", this.id)\n    }\n\n    /** Deletes the text style from the project. */\n    async remove(): Promise<void> {\n        return this.#api.invoke(\"removeTextStyle\", this.id)\n    }\n}\n\nexport function isTextStyle(value: unknown): value is TextStyle {\n    return value instanceof TextStyle\n}\n\nexport function toTextStyleData(textStyle: TextStyle): TextStyleData {\n    return {\n        __class: \"TextStyle\",\n\n        id: textStyle.id,\n        name: textStyle.name,\n        tag: textStyle.tag,\n\n        font: toFontData(textStyle.font),\n        boldFont: textStyle.boldFont ? toFontData(textStyle.font) : null,\n        italicFont: textStyle.italicFont ? toFontData(textStyle.italicFont) : null,\n        boldItalicFont: textStyle.boldItalicFont ? toFontData(textStyle.boldItalicFont) : null,\n        color: textStyle.color,\n        transform: textStyle.transform,\n        alignment: textStyle.alignment,\n        decoration: textStyle.decoration,\n        balance: textStyle.balance,\n        breakpoints: textStyle.breakpoints,\n\n        minWidth: textStyle.minWidth,\n        fontSize: textStyle.fontSize,\n        letterSpacing: textStyle.letterSpacing,\n        lineHeight: textStyle.lineHeight,\n        paragraphSpacing: textStyle.paragraphSpacing,\n    }\n}\n","import type { FileAssetData, ImageAssetData } from \"./assets\"\nimport type { Font, FontData } from \"./fonts\"\nimport type { FramerPluginAPI } from \"./framerAPI\"\nimport type { Gradient, GradientData } from \"./gradients\"\nimport type { TextStyleData } from \"./styles\"\n\nimport { FileAsset, ImageAsset, isFileAsset, isFileAssetData, isImageAsset, isImageAssetData } from \"./assets\"\nimport { createFont, isFont, toFontData } from \"./fonts\"\nimport { createGradient, isGradient, isGradientData, toGradientData } from \"./gradients\"\nimport { isTextStyle, TextStyle, toTextStyleData } from \"./styles\"\nimport { assertNever, isArray, isObject } from \"./utils\"\n\ntype SerializableAttribute = ImageAsset | Gradient | FileAsset | Font\ntype SerializedAttribute = ImageAssetData | GradientData | FileAssetData | TextStyleData | FontData\n\nexport function serializeAttributes(value: unknown): unknown {\n    if (isSerializableAttribute(value)) {\n        return serializeAttribute(value)\n    }\n\n    if (isArray(value)) {\n        return value.map(serializeAttributes)\n    }\n\n    if (isObject(value)) {\n        const result: Record<string, unknown> = {}\n        for (const key in value) {\n            result[key] = serializeAttributes(value[key])\n        }\n\n        return result\n    }\n\n    return value\n}\n\nexport function reviveAttributes(value: Record<string, unknown>, api: FramerPluginAPI): Record<string, unknown> {\n    const result: Record<string, unknown> = {}\n    for (const key in value) {\n        result[key] = reviveAttribute(value[key], api)\n    }\n\n    return result\n}\n\nexport function reviveAttribute(value: unknown, api: FramerPluginAPI): unknown {\n    if (isSerializedAttribute(value)) {\n        switch (value.__class) {\n            case \"ImageAsset\":\n                return new ImageAsset(value, api)\n            case \"FileAsset\":\n                return new FileAsset(value)\n            case \"LinearGradient\":\n            case \"RadialGradient\":\n            case \"ConicGradient\":\n                return createGradient(value)\n            case \"TextStyle\":\n                return new TextStyle(value, api)\n            case \"Font\":\n                return createFont(value)\n            default:\n                assertNever(value)\n        }\n    }\n\n    if (isObject(value)) {\n        const result: Record<string, unknown> = {}\n        for (const key in value) {\n            result[key] = reviveAttribute(value[key], api)\n        }\n\n        return result\n    }\n\n    if (isArray(value)) {\n        return value.map(item => reviveAttribute(item, api))\n    }\n\n    return value\n}\n\nfunction isSerializedAttribute(value: unknown): value is SerializedAttribute {\n    if (isImageAssetData(value)) return true\n    if (isFileAssetData(value)) return true\n    if (isGradientData(value)) return true\n\n    return false\n}\n\nexport function isSerializableAttribute(value: unknown): value is SerializableAttribute {\n    if (isImageAsset(value)) return true\n    if (isFileAsset(value)) return true\n    if (isGradient(value)) return true\n    if (isTextStyle(value)) return true\n    if (isFont(value)) return true\n\n    return false\n}\n\nfunction serializeAttribute(value: SerializableAttribute): SerializedAttribute {\n    if (isImageAsset(value)) {\n        const data: ImageAssetData = {\n            __class: \"ImageAsset\",\n            id: value.id,\n            thumbnailUrl: value.thumbnailUrl,\n            url: value.url,\n            altText: value.altText,\n        }\n\n        return data\n    }\n\n    if (isFileAsset(value)) {\n        const data: FileAssetData = {\n            __class: \"FileAsset\",\n            id: value.id,\n            extension: value.extension,\n            url: value.url,\n        }\n\n        return data\n    }\n\n    if (isGradient(value)) {\n        return toGradientData(value)\n    }\n\n    if (isTextStyle(value)) {\n        return toTextStyleData(value)\n    }\n\n    if (isFont(value)) {\n        return toFontData(value)\n    }\n\n    assertNever(value)\n}\n","import type { FramerAPI, FramerPluginAPI } from \"./framerAPI\"\nimport type { WithInvoke } from \"./invoke\"\nimport type { NodeId } from \"./traits\"\n\nimport { FileAsset, ImageAsset, isFileAssetData, isImageAssetData } from \"./assets\"\nimport { withInvoke } from \"./invoke\"\nimport { assert, isString } from \"./utils\"\n\nexport interface CollectionData {\n    id: string\n    name: string\n}\n\nexport type FieldData = Record<string, unknown>\n\nexport interface EditableCollectionItemAttributes {\n    /** Required unique slug. */\n    slug: string\n    /** Data for the fields. */\n    fieldData: FieldData\n}\n\nexport interface CollectionItemData extends EditableCollectionItemAttributes {\n    /** Required unique id. Using an id instead of the slug prevents data loss. */\n    id: string\n}\n\ninterface FieldBase {\n    /** Required unique id. Use a unique identifier to prevent data loss when the field is renamed. */\n    id: string\n    /** The name of the field as displayed in the UI. */\n    name: string\n}\n\nexport interface BooleanField extends FieldBase {\n    type: \"boolean\"\n}\n\nexport interface ColorField extends FieldBase {\n    type: \"color\"\n}\n\nexport interface NumberField extends FieldBase {\n    type: \"number\"\n}\n\nexport interface StringField extends FieldBase {\n    type: \"string\"\n}\n\nexport interface FormattedTextField extends FieldBase {\n    type: \"formattedText\"\n}\n\nexport interface ImageField extends FieldBase {\n    type: \"image\"\n}\n\nexport interface LinkField extends FieldBase {\n    type: \"link\"\n}\n\nexport interface DateField extends FieldBase {\n    type: \"date\"\n}\n\nexport interface FileField extends FieldBase {\n    type: \"file\"\n    allowedFileTypes: string[]\n}\n\nexport interface EnumCase {\n    id: string\n    name: string\n}\n\nexport interface EnumField extends FieldBase {\n    type: \"enum\"\n    cases: EnumCase[]\n}\n\nexport interface UnsupportedField extends FieldBase {\n    type: \"unsupported\"\n}\n\n/**\n * A collection field that Framer knows about and the plugin API fully supports.\n */\nexport type SupportedCollectionField =\n    | BooleanField\n    | ColorField\n    | NumberField\n    | StringField\n    | FormattedTextField\n    | ImageField\n    | LinkField\n    | DateField\n    | FileField\n    | EnumField\n\n/**\n * Any kind of collection field definition. The field may be unsupported by the\n * plugin API.\n */\nexport type CollectionField = SupportedCollectionField | UnsupportedField\n\n/**\n * Any kind of collection field definition that was created by a plugin and is\n * supported by the API.\n */\nexport type ManagedCollectionField = SupportedCollectionField & {\n    /** Is the user able to edit the field within the UI. */\n    userEditable: boolean\n}\n\nexport type EditableManagedCollectionField = SupportedCollectionField &\n    Partial<Pick<ManagedCollectionField, \"userEditable\">>\n\nconst allSupportedFieldTypes: Record<SupportedCollectionField[\"type\"], true> = {\n    string: true,\n    number: true,\n    boolean: true,\n    color: true,\n    formattedText: true,\n    image: true,\n    link: true,\n    date: true,\n    file: true,\n    enum: true,\n}\n\nexport function isSupportedCollectionFieldType(type: string): type is SupportedCollectionField[\"type\"] {\n    return allSupportedFieldTypes[type as SupportedCollectionField[\"type\"]] === true\n}\n\n/**\n * Returns `true` if the collection field is implemented in the plugin API.\n * */\nexport function isSupportedCollectionField(field: CollectionField): field is SupportedCollectionField {\n    return isSupportedCollectionFieldType(field.type)\n}\n\n/**\n * Replace any asset data with instances of `ImageAsset` or `FileAsset`.\n *\n * @param fieldData - This object will be mutated.\n */\nfunction createAssetInstancesForFieldData(fieldData: FieldData, api: WithInvoke & FramerAPI): void {\n    for (const key in fieldData) {\n        const value = fieldData[key]\n\n        if (isImageAssetData(value)) {\n            fieldData[key] = new ImageAsset(value, api)\n        }\n\n        if (isFileAssetData(value)) {\n            fieldData[key] = new FileAsset(value)\n        }\n    }\n}\n\nexport class ManagedCollection {\n    readonly id: NodeId\n    readonly name: string\n\n    // We use `#` to make sure the api can not be observed when a user logs or loops over a node\n    // instance.\n    #api: WithInvoke\n\n    constructor(data: Partial<CollectionData>, api: FramerPluginAPI) {\n        assert(isString(data.id), \"Node must have an id\")\n        assert(isString(data.name), \"Node must have a name\")\n        this.id = data.id\n        this.name = data.name\n\n        assert(withInvoke(api))\n        this.#api = api\n\n        Object.freeze(this)\n    }\n\n    /** Get item keys in their set order. */\n    async getItemIds() {\n        return this.#api.invoke(\"getManagedCollectionItemIds\", this.id)\n    }\n\n    /** Arrange items in a specific order. */\n    async setItemOrder(ids: string[]) {\n        return this.#api.invoke(\"setManagedCollectionItemOrder\", this.id, ids)\n    }\n\n    /** Get all fields. */\n    async getFields() {\n        return this.#api.invoke(\"getManagedCollectionFields\", this.id)\n    }\n\n    /** Create, update or remove all fields in one go. */\n    async setFields(fields: EditableManagedCollectionField[]) {\n        return this.#api.invoke(\"setManagedCollectionFields\", this.id, fields)\n    }\n\n    /** Add new items or update existing ones if their IDs match. */\n    async addItems(items: CollectionItemData[]) {\n        return this.#api.invoke(\"addManagedCollectionItems\", this.id, items)\n    }\n\n    /** Remove items by their id. */\n    async removeItems(ids: string[]) {\n        return this.#api.invoke(\"removeManagedCollectionItems\", this.id, ids)\n    }\n\n    /** Set plugin data by key. */\n    async setPluginData(key: string, value: string | null) {\n        return this.#api.invoke(\"setPluginDataForNode\", this.id, key, value)\n    }\n\n    /** Get plugin data by key. */\n    async getPluginData(key: string) {\n        return this.#api.invoke(\"getPluginDataForNode\", this.id, key)\n    }\n\n    /** Get all plugin data keys. */\n    async getPluginDataKeys() {\n        return this.#api.invoke(\"getPluginDataKeysForNode\", this.id)\n    }\n}\n\nexport class Collection {\n    readonly id: NodeId\n    readonly name: string\n\n    #api: WithInvoke & FramerAPI\n\n    constructor(data: Partial<CollectionData>, api: FramerPluginAPI) {\n        assert(isString(data.id), \"Node must have an id\")\n        assert(isString(data.name), \"Node must have a name\")\n        this.id = data.id\n        this.name = data.name\n\n        assert(withInvoke(api))\n        this.#api = api\n\n        Object.freeze(this)\n    }\n\n    /** Get all fields. */\n    async getFields(): Promise<CollectionField[]> {\n        return this.#api.invoke(\"getCollectionFields\", this.id)\n    }\n\n    /* Get all items in their set order. */\n    async getItems(): Promise<CollectionItem[]> {\n        const itemsData = await this.#api.invoke(\"getCollectionItems\", this.id)\n\n        return itemsData.map(itemData => {\n            return new CollectionItem(itemData, this.#api)\n        })\n    }\n\n    /** Set plugin data by key. */\n    async setPluginData(key: string, value: string | null) {\n        return this.#api.invoke(\"setPluginDataForNode\", this.id, key, value)\n    }\n\n    /** Get plugin data by key. */\n    async getPluginData(key: string) {\n        return this.#api.invoke(\"getPluginDataForNode\", this.id, key)\n    }\n\n    /** Get all plugin data keys. */\n    async getPluginDataKeys() {\n        return this.#api.invoke(\"getPluginDataKeysForNode\", this.id)\n    }\n}\n\nexport class CollectionItem {\n    readonly id: string\n    readonly slug: string\n    readonly fieldData: Readonly<FieldData>\n\n    #api: WithInvoke & FramerAPI\n\n    constructor(data: CollectionItemData, api: WithInvoke & FramerAPI) {\n        this.id = data.id\n        this.slug = data.slug\n\n        this.fieldData = data.fieldData\n        createAssetInstancesForFieldData(this.fieldData, api)\n\n        assert(withInvoke(api))\n        this.#api = api\n\n        Object.freeze(this)\n        Object.freeze(this.fieldData)\n    }\n\n    /** Set plugin data by key. */\n    async setPluginData(key: string, value: string | null) {\n        return this.#api.invoke(\"setPluginDataForNode\", this.id, key, value)\n    }\n\n    /** Get plugin data by key. */\n    async getPluginData(key: string) {\n        return this.#api.invoke(\"getPluginDataForNode\", this.id, key)\n    }\n\n    /** Get all plugin data keys. */\n    async getPluginDataKeys() {\n        return this.#api.invoke(\"getPluginDataKeysForNode\", this.id)\n    }\n}\n","import type { FramerAPI } from \"./framerAPI\"\nimport type { EditableComponentInstanceNodeAttributes } from \"./nodes\"\n\nimport { withInvoke } from \"./invoke\"\nimport { assert } from \"./utils\"\n\nconst pointerEvents = (() => {\n    let style: HTMLStyleElement | null = null\n\n    return {\n        /** Disable pointer events on all elements until a mouse up is detected. */\n        disableUntilMouseUp: () => {\n            if (style) return\n\n            style = document.createElement(\"style\")\n            style.textContent =\n                \"* { pointer-events: none !important; user-select: none !important; -webkit-user-select: none !important; }\"\n            document.head.appendChild(style)\n\n            const enablePointerEvents = () => {\n                if (!style) return\n\n                document.head.removeChild(style)\n                style = null\n\n                cleanup()\n            }\n\n            const handlePointerChange = (event: PointerEvent) => {\n                const mainButtonPressed = event.buttons > 0 && Boolean(event.buttons & 1)\n                if (mainButtonPressed) return\n                enablePointerEvents()\n            }\n\n            const handleBlur = () => {\n                enablePointerEvents()\n            }\n\n            window.addEventListener(\"pointerup\", handlePointerChange, true)\n            window.addEventListener(\"pointermove\", handlePointerChange, true)\n            window.addEventListener(\"blur\", handleBlur)\n\n            function cleanup() {\n                window.removeEventListener(\"pointerup\", handlePointerChange, true)\n                window.removeEventListener(\"pointermove\", handlePointerChange, true)\n                window.removeEventListener(\"blur\", handleBlur)\n            }\n        },\n    }\n})()\n\nconst moveThreshold = 5\n\ninterface WithOptionalName {\n    name?: string\n}\n\ninterface WithOptionalPreviewImage {\n    previewImage?: string\n}\n\ninterface SvgDragData extends WithOptionalName, WithOptionalPreviewImage {\n    type: \"svg\"\n    svg: string\n    /** Inverts SVG drag preview in dark mode. Defaults to true. */\n    invertInDarkMode