es } from \"./attributes\"\nimport { Collection, ManagedCollection } from \"./collections\"\nimport { makeDraggable } from \"./dragging\"\nimport { FramerPluginError } from \"./errors\"\nimport { createFont } from \"./fonts\"\nimport { isMode, isVekterToPluginMessage } from \"./messages\"\nimport {\n    convertEditableAttributesToNodeData,\n    convertRawNodeDataToNode,\n    FrameNode,\n    isCanvasNode,\n    isCanvasRootNode,\n    isComponentInstanceNode,\n    isFrameNode,\n} from \"./nodes\"\nimport { ColorStyle, TextStyle } from \"./styles\"\nimport { withDisabledCssTransitions } from \"./theme\"\nimport { assert, assertNever, isObject, isString } from \"./utils\"\n\nexport type Unsubscribe = VoidFunction\nexport type Cleanup = VoidFunction\n\nexport type { Mode } from \"./messages\"\n\n/** We up the number when plugins are no longer compatible. */\nexport const breakingChangesVersion = 2\n\ntype PostMessage = (message: PluginToVekterMessage, transfer?: Transferable[] | undefined) => void\n\ntype SubscriptionHandler = (value: unknown) => void\n\nexport class FramerPluginAPI implements FramerAPI {\n    #methodInvocationId = 0\n    #notificationId = 0\n\n    #initialMessageQueue: [PluginToVekterMessage, Transferable[] | undefined][] = []\n    #postMessage: PostMessage | undefined = undefined\n    #methodResponseHandlers = new Map<\n        PluginMessageId,\n        { resolve: (value: unknown) => void; reject: (error: FramerPluginError) => void }\n    >()\n    #mode: Mode\n\n    private subscriptions: Map<PluginSubscriptionTopic, Set<SubscriptionHandler>> = new Map()\n\n    constructor({ isTestEnv }: { isTestEnv?: boolean } = {}) {\n        if (isTestEnv) {\n            this.#mode = \"canvas\"\n            return\n        }\n\n        if (typeof window === \"undefined\") {\n            // When framer-plugin is imported in a node a node environment, window is not defined.\n            // If you import the package in a module that is not a browser environment it can cause errors\n            // Because we create a singleton instance of the plugin API when the package is imported and reference window.\n            // Instead we will no-op and return the canvas mode to not crash.\n\n            // eslint-disable-next-line no-console\n            console.warn(\"Framer Plugin API is not supported in non-browser environments\")\n\n            this.#mode = \"canvas\"\n            return\n        }\n\n        const url = new URL(window.location.href)\n        const mode = url.searchParams.get(\"mode\")\n        assert(isMode(mode), `Invalid mode: ${mode}`)\n        this.#mode = mode\n\n        window.addEventListener(\"message\", this.onMessage)\n\n        const readySignal: PluginReadySignal = {\n            type: \"pluginReadySignal\",\n            breakingChangesVersion,\n        }\n        window.parent.postMessage(readySignal, \"*\")\n        this.subscribe(\"theme\", this.applyPluginTheme)\n\n        window.addEventListener(\"pointerdown\", () => {\n            void this.invoke(\"onPointerDown\")\n        })\n    }\n\n    get mode(): Mode {\n        return this.#mode\n    }\n\n    private invoke<\n        Name extends keyof PluginMessageAPI,\n        Args extends Parameters<PluginMessageAPI[Name]>,\n        Return extends ReturnType<PluginMessageAPI[Name]>,\n    >(methodName: Name, ...args: Args): Promise<Awaited<Return>> {\n        return this.invokeTransferable(methodName, undefined, ...args)\n    }\n\n    private invokeTransferable<\n        Name extends keyof PluginMessageAPI,\n        Args extends Parameters<PluginMessageAPI[Name]>,\n        Return extends ReturnType<PluginMessageAPI[Name]>,\n    >(methodName: Name, transfer: Transferable[] | undefined, ...args: Args): Promise<Awaited<Return>> {\n        return new Promise((resolve, reject) => {\n            const message: PluginMethodInvocation = {\n                args,\n                methodName,\n                id: this.#methodInvocationId++,\n                type: \"methodInvocation\",\n            }\n\n            const typedResolve = resolve as (value: unknown) => void\n            this.#methodResponseHandlers.set(message.id, { resolve: typedResolve, reject })\n\n            this.queueMessage(message, transfer)\n        }) as Promise<Awaited<Return>>\n    }\n\n    private subscribe<\n        Topic extends PluginSubscriptionTopic,\n        Event extends Extract<PluginSubscriptionEvent, { topic: Topic }>,\n    >(topic: Topic, callback: (data: Event[\"payload\"]) => void): VoidFunction {\n        this.queueMessage({\n            type: \"subscribe\",\n            topic,\n        })\n\n        const nextSubscriptions = this.subscriptions.get(topic) ?? new Set()\n        nextSubscriptions.add(callback as (value: unknown) => void)\n        this.subscriptions.set(topic, nextSubscriptions)\n\n        return () => {\n            const subscriptions = this.subscriptions.get(topic) ?? new Set()\n            subscriptions.delete(callback as SubscriptionHandler)\n\n            if (subscriptions.size === 0) {\n                this.queueMessage({\n                    type: \"unsubscribe\",\n                    topic,\n                })\n            }\n\n            this.subscriptions.set(topic, subscriptions)\n        }\n    }\n\n    private queueMessage(message: PluginMethodInvocation | PluginSubscription, transfer?: Transferable[] | undefined) {\n        if (!this.#postMessage) {\n            this.#initialMessageQueue.push([message, transfer])\n            return\n        }\n\n        this.#postMessage(message, transfer)\n    }\n\n    private onMessage = (event: MessageEvent) => {\n        const message = event.data\n        if (!isVekterToPluginMessage(message)) {\n            return\n        }\n\n        switch (message.type) {\n            case \"pluginReadyResponse\": {\n                const source = event.source\n                if (!source) {\n                    throw new Error(\"No 'source' on incoming message: \" + message.type)\n                }\n\n                assert(this.#mode === message.mode, \"Mode must match\")\n                this.applyPluginTheme(message.theme)\n\n                // Transferable only exists on window.parent.postMessage and not source.postMessage\n                this.#postMessage = (message, transfer) => window.parent.postMessage(message, event.origin, transfer)\n\n                for (const item of this.#initialMessageQueue) {\n                    this.#postMessage(...item)\n                }\n                this.#initialMessageQueue = []\n                break\n            }\n            case \"methodResponse\": {\n                const responseHandlers = this.#methodResponseHandlers.get(message.id)\n                if (!responseHandlers) {\n                    throw new Error(`No handler for response with id ${message.id}`)\n                }\n\n                this.#methodResponseHandlers.delete(message.id)\n\n                if (message.error) {\n                    responseHandlers.reject(new FramerPluginError(message.error))\n                } else {\n                    responseHandlers.resolve(message.result)\n                }\n\n                break\n            }\n            case \"subscriptionMessage\": {\n                const { topic, payload } = message\n\n                const handlers = this.subscriptions.get(topic)\n                if (!handlers) {\n                    // Could be a race condition to return null?\n                    throw new Error(\"Received a subscription message but no handler present\")\n                }\n\n                for (const handler of handlers) {\n                    handler(payload)\n                }\n\n                break\n            }\n            default: {\n                assertNever(message)\n            }\n        }\n    }\n\n    // This handler is is only active when a window is visible.\n    private applyPluginTheme = (theme: Theme) => {\n        withDisabledCssTransitions(() => {\n            document.body.setAttribute(\"data-framer-theme\", theme.mode)\n\n            for (const key in theme.tokens) {\n                document.body.style.setProperty(key, theme.tokens[key as keyof typeof theme.tokens])\n            }\n        })\n    }\n\n    async showUI(options?: UIOptions): Promise<void> {\n        return this.invoke(\"showUI\", options)\n    }\n\n    async hideUI(): Promise<void> {\n        return this.invoke(\"hideUI\")\n    }\n\n    async closePlugin(message?: string, options?: ClosePluginOptions): Promise<void> {\n        return this.invoke(\"closePlugin\", message, options)\n    }\n\n    async getCurrentUser(): Promise<User> {\n        return this.invoke(\"getCurrentUser\")\n    }\n\n    async getSelection() {\n        const nodesData = await this.invoke(\"getSelection\")\n        return nodesData.map(nodeData => {\n            const node = convertRawNodeDataToNode(nodeData, this)\n            assert(isCanvasNode(node))\n            return node\n        })\n    }\n\n    async setSelection(nodeIds: string | Iterable<string>) {\n        const rpcNodeIds = isString(nodeIds) ? [nodeIds] : Array.from(nodeIds)\n\n        return this.invoke(\"setSelection\", rpcNodeIds)\n    }\n\n    subscribeToSelection(callback: (result: CanvasNode[]) => void): VoidFunction {\n        return this.subscribe(\"selection\", nodesData => {\n            const nodes = nodesData.map(nodeData => {\n                const node = convertRawNodeDataToNode(nodeData, this)\n                assert(isCanvasNode(node))\n                return node\n            })\n            callback(nodes)\n        })\n    }\n\n    async getCanvasRoot() {\n        const root = await this.invoke(\"getCanvasRoot\")\n        const node = convertRawNodeDataToNode(root, this)\n\n        assert(isCanvasRootNode(node))\n\n        return node\n    }\n\n    subscribeToCanvasRoot(callback: (data: CanvasRootNode) => void): VoidFunction {\n        return this.subscribe(\"canvasRoot\", data => {\n            const instance = convertRawNodeDataToNode(data, this)\n            assert(isCanvasRootNode(instance))\n            callback(instance)\n        })\n    }\n\n    async getPublishInfo() {\n        return this.invoke(\"getPublishInfo\")\n    }\n\n    subscribeToPublishInfo(callback: (data: PublishInfo) => void): VoidFunction {\n        return this.subscribe(\"publishInfo\", callback)\n    }\n\n    async createFrameNode(\n        attributes: Partial<EditableFrameNodeAttributes>,\n        parentId?: string\n    ): Promise<FrameNode | null> {\n        const attributesData = convertEditableAttributesToNodeData(attributes)\n        const rawData = await this.invoke(\"createNode\", \"FrameNode\", parentId ?? null, attributesData)\n        if (!rawData) return null\n\n        const node = convertRawNodeDataToNode(rawData, this)\n\n        assert(node instanceof FrameNode)\n\n        return node\n    }\n\n    async removeNode(nodeId: string): Promise<void> {\n        return this.invoke(\"removeNode\", nodeId)\n    }\n\n    async cloneNode(nodeId: string): Promise<AnyNode | null> {\n        const nodeData = await this.invoke(\"cloneNode\", nodeId)\n        if (!nodeData) return null\n        return convertRawNodeDataToNode(nodeData, this)\n    }\n\n    async getNode(nodeId: string): Promise<AnyNode | null> {\n        const nodeData = await this.invoke(\"getNode\", nodeId)\n        if (!nodeData) return null\n        return convertRawNodeDataToNode(nodeData, this)\n    }\n\n    async getParent(nodeId: string): Promise<AnyNode | null> {\n        const rawData = await this.invoke(\"getParent\", nodeId)\n        if (!rawData) return null\n        return convertRawNodeDataToNode(rawData, this)\n    }\n\n    async getChildren(nodeId: string): Promise<CanvasNode[]> {\n        const nodesData = await this.invoke(\"getChildren\", nodeId)\n        return nodesData.map(nodeData => {\n            const node = convertRawNodeDataToNode(nodeData, this)\n            assert(isCanvasNode(node))\n            return node\n        })\n    }\n\n    async getRect(nodeId: string): Promise<Rect | null> {\n        return this.invoke(\"getRect\", nodeId)\n    }\n\n    async zoomIntoView(nodeIds: string | Iterable<string>, options?: ZoomIntoViewOptions): Promise<void> {\n        const rpcNodeIds = isString(nodeIds) ? [nodeIds] : Array.from(nodeIds)\n\n        return this.invoke(\"zoomIntoView\", rpcNodeIds, options)\n    }\n\n    async setAttributes(nodeId: string, attributes: Partial<AnyEditableAttributes>): Promise<AnyNode | null> {\n        const attributesData = convertEditableAttributesToNodeData(attributes)\n        const nodeData = await this.invoke(\"setAttributes\", nodeId, attributesData)\n\n        if (!nodeData) return null\n        return convertRawNodeDataToNode(nodeData, this)\n    }\n\n    async setParent(nodeId: string, parentId: string, index?: number | undefined) {\n        return this.invoke(\"setParent\", nodeId, parentId, index)\n    }\n\n    getNodesWithType(type: \"FrameNode\"): Promise<FrameNode[]>\n    getNodesWithType(type: \"TextNode\"): Promise<TextNode[]>\n    getNodesWithType(type: \"SVGNode\"): Promise<SVGNode[]>\n    getNodesWithType(type: \"ComponentInstanceNode\"): Promise<ComponentInstanceNode[]>\n    getNodesWithType(type: \"WebPageNode\"): Promise<WebPageNode[]>\n    getNodesWithType(type: \"ComponentNode\"): Promise<ComponentNode[]>\n    async getNodesWithType(type: KnownNodeClass) {\n        const nodesData = await this.invoke(\"getNodesWithType\", null, type)\n        return nodesData.map(nodeData => convertRawNodeDataToNode(nodeData, this))\n    }\n\n    async getNodesWithAttribute<T extends NodeAttributeKey, Node = NodeWithAttribute<T>>(\n        attribute: T\n    ): Promise<Node[]> {\n        const nodesData = await this.invoke(\"getNodesWithAttribute\", null, attribute)\n        return nodesData.map(nodeData => convertRawNodeDataToNode(nodeData, this) as Node)\n    }\n\n    async getNodesWithAttributeSet<T extends NodeAttributeKey, Node = NodeWithAttribute<T>>(\n        attribute: T\n    ): Promise<Node[]> {\n        const nodesData = await this.invoke(\"getNodesWithAttributeSet\", null, attribute)\n        return nodesData.map(nodeData => convertRawNodeDataToNode(nodeData, this) as Node)\n    }\n\n    async getImage(): Promise<ImageAsset | null> {\n        const data = await this.invoke(\"getImage\")\n\n        if (!data) return null\n\n        return new ImageAsset(data, this)\n    }\n\n    subscribeToImage(callback: (image: ImageAsset | null) => void): Unsubscribe {\n        return this.subscribe(\"image\", imageAssetData => {\n            if (!imageAssetData) {\n                callback(null)\n                return\n            }\n\n            callback(new ImageAsset(imageAssetData, this))\n        })\n    }\n\n    async addImage(input: NamedImageAssetInput | File): Promise<void> {\n        const transferData = await createImageTransferFromInput(input)\n        const transferable = getTransferable(transferData)\n\n        return this.invokeTransferable(\"addImage\", transferable, transferData)\n    }\n\n    async setImage(input: NamedImageAssetInput | File): Promise<void> {\n        const transferData = await createImageTransferFromInput(input)\n        const transferable = getTransferable(transferData)\n        return this.invokeTransferable(\"setImage\", transferable, transferData)\n    }\n\n    async uploadImage(input: NamedImageAssetInput | File): Promise<ImageAsset> {\n        const transferData = await createImageTransferFromInput(input)\n        const transferable = getTransferable(transferData)\n        const data = await this.invokeTransferable(\"uploadImage\", transferable, transferData)\n\n        return new ImageAsset(data, this)\n    }\n\n    async addImages(input: readonly NamedImageAssetInput[]): Promise<void> {\n        const data = await createNamedAssetDataTransferFromInput(input)\n        const buffers = data.flatMap(getTransferable)\n        await this.invokeTransferable(\"addImages\", buffers, data)\n    }\n\n    async uploadImages(input: readonly NamedImageAssetInput[]): Promise<ImageAsset[]> {\n        const data = await createNamedAssetDataTransferFromInput(input)\n        const buffers = data.flatMap(getTransferable)\n        const response = await this.invokeTransferable(\"uploadImages\", buffers, data)\n\n        const result: ImageAsset[] = []\n        for (const item of response) {\n            result.push(new ImageAsset(item, this))\n        }\n\n        return result\n    }\n\n    async uploadFile(file: NamedFileAssetInput | File): Promise<FileAsset> {\n        const data = await createFileTransferFromInput(file)\n        const response = await this.invokeTransferable(\"uploadFile\", getTransferable(data), data)\n\n        return new FileAsset(response)\n    }\n\n    async uploadFiles(files: readonly NamedFileAssetInput[]): Promise<FileAsset[]> {\n        const data = await Promise.all(files.map(createFileTransferFromInput))\n        const buffers = data.flatMap(getTransferable)\n        const response = await this.invokeTransferable(\"uploadFiles\", buffers, data)\n\n        const result: FileAsset[] = []\n        for (const item of response) {\n            result.push(new FileAsset(item))\n        }\n\n        return result\n    }\n\n    async addSVG(svg: SVGData): Promise<void> {\n        return this.invoke(\"addSVG\", svg)\n    }\n\n    async addComponentInstance({ url, attributes }: AddComponentInstanceOptions): Promise<ComponentInstanceNode> {\n        const serializedAttributes = serializeAttributes(attributes)\n        const nodeData = await this.invoke(\"addComponentInstance\", {\n            url,\n            attributes: isObject(serializedAttributes) ? serializedAttributes : undefined,\n        })\n        const node = convertRawNodeDataToNode(nodeData, this)\n        assert(isComponentInstanceNode(node))\n        return node\n    }\n\n    async addDetachedComponentLayers({\n        url,\n        layout,\n        attributes,\n    }: AddDetachedComponentLayersOptions): Promise<FrameNode> {\n        const serializedAttributes = serializeAttributes(attributes)\n        const nodeData = await this.invoke(\"addDetachedComponentLayers\", {\n            url,\n            layout,\n            attributes: isObject(serializedAttributes) ? serializedAttributes : undefined,\n        })\n        const node = convertRawNodeDataToNode(nodeData, this)\n        assert(isFrameNode(node))\n        return node\n    }\n\n    async preloadDetachedComponentLayers(url: string) {\n        await this.invoke(\"preloadDetachedComponentLayers\", url)\n    }\n\n    async preloadImageUrlForInsertion(url: string) {\n        await this.invoke(\"preloadImageUrlForInsertion\", url)\n    }\n\n    async preloadDragPreviewImage(url: string) {\n        await this.invoke(\"preloadDragPreviewImage\", url)\n    }\n\n    async getText() {\n        return this.invoke(\"getText\")\n    }\n\n    async setText(text: string) {\n        return this.invoke(\"setText\", text)\n    }\n\n    async addText(text: string, options?: AddTextOptions) {\n        return this.invoke(\"addText\", text, options)\n    }\n\n    async setCustomCode(options: SetCustomCodeOptions) {\n        return this.invoke(\"setCustomCode\", options)\n    }\n\n    async getCustomCode() {\n        return this.invoke(\"getCustomCode\")\n    }\n\n    subscribeToCustomCode(callback: (customHTML: CustomCode) => void) {\n        return this.subscribe(\"customCode\", callback)\n    }\n\n    subscribeToText(callback: (text: string | null) => void): Unsubscribe {\n        return this.subscribe(\"text\", callback)\n    }\n\n    makeDraggable(element: HTMLElement, getDragData: () => DragData): Cleanup {\n        return makeDraggable(this, element, getDragData)\n    }\n\n    async getManagedCollection(): Promise<ManagedCollection> {\n        const collectionData = await this.invoke(\"getManagedCollection\")\n        assert(collectionData, \"Collection data must be defined\")\n\n        return new ManagedCollection(collectionData, this)\n    }\n\n    async getCollection(): Promise<Collection> {\n        const collectionData = await this.invoke(\"getCollection\")\n        assert(collectionData, \"Collection data must be defined\")\n\n        return new Collection(collectionData, this)\n    }\n\n    async getCollections(): Promise<Collection[]> {\n        const collectionsData = await this.invoke(\"getCollections\")\n\n        return collectionsData.map(collectionData => {\n            return new Collection(collectionData, this)\n        })\n    }\n\n    notify(message: string, options?: NotifyOptions): Notification {\n        const notificationId = `notification-${this.#notificationId++}`\n\n        void this.invoke(\"notify\", message, {\n            notificationId,\n            variant: options?.variant ?? \"info\",\n            buttonText: options?.button?.text,\n            durationMs: options?.durationMs,\n        }).then(closeReason => {\n            if (closeReason === \"actionButtonClicked\" && options?.button?.onClick) {\n                options.button.onClick()\n            }\n\n            if (options?.onDisappear) {\n                options.onDisappear()\n            }\n        })\n\n        return {\n            close: () => this.invoke(\"closeNotification\", notificationId),\n        }\n    }\n\n    async getPluginData(key: string): Promise<string | null> {\n        return this.invoke(\"getPluginData\", key)\n    }\n\n    async setPluginData(key: string, value: string | null): Promise<void> {\n        return this.invoke(\"setPluginData\", key, value)\n    }\n\n    async getPluginDataKeys(): Promise<string[]> {\n        return this.invoke(\"getPluginDataKeys\")\n    }\n\n    async getColorStyles(): Promise<ColorStyle[]> {\n        const colorStylesData = await this.invoke(\"getColorStyles\")\n\n        return colorStylesData.map(colorStyleData => {\n            return new ColorStyle(colorStyleData, this)\n        })\n    }\n\n    async getColorStyle(id: string): Promise<ColorStyle | null> {\n        const colorStyleData = await this.invoke(\"getColorStyle\", id)\n        if (!colorStyleData) return null\n\n        return new ColorStyle(colorStyleData, this)\n    }\n\n    async createColorStyle(attributes: ColorStyleAttributes): Promise<ColorStyle> {\n        const colorStyleData = await this.invoke(\"createColorStyle\", attributes)\n        return new ColorStyle(colorStyleData, this)\n    }\n\n    subscribeToColorStyles(callback: (styles: ColorStyle[]) => void) {\n        return this.subscribe(\"colorStyles\", colorStylesData => {\n            const colorStyles = colorStylesData.map((colorStyleData): ColorStyle => {\n                return new ColorStyle(colorStyleData, this)\n            })\n\n            return callback(colorStyles)\n        })\n    }\n\n    async getTextStyles(): Promise<TextStyle[]> {\n        const textStylesData = await this.invoke(\"getTextStyles\")\n\n        return textStylesData.map(textStyleData => {\n            return new TextStyle(textStyleData, this)\n        })\n    }\n\n    async getTextStyle(id: string): Promise<TextStyle | null> {\n        const textStyleData = await this.invoke(\"getTextStyle\", id)\n        if (!textStyleData) return null\n\n        return new TextStyle(textStyleData, this)\n    }\n\n    async createTextStyle(attributes: TextStyleAttributes): Promise<TextStyle> {\n        const textStyleData = await this.invoke(\"createTextStyle\", attributes)\n        return new TextStyle(textStyleData, this)\n    }\n\n    subscribeToTextStyles(callback: (styles: TextStyle[]) => void) {\n        return this.subscribe(\"textStyles\", textStylesData => {\n            const textStyles = textStylesData.map((textStyleData): TextStyle => {\n                return new TextStyle(textStyleData, this)\n            })\n\n            return callback(textStyles)\n        })\n    }\n\n    async getFont(family: string, attributes?: FontAttributes): Promise<Font | null> {\n        const fontData = await this.invoke(\"getFont\", family, attributes)\n        if (!fontData) return null\n\n        return createFont(fontData)\n    }\n\n    async getFonts(): Promise<Font[]> {\n        const fontData = await this.invoke(\"getFonts\")\n\n        return fontData.map(createFont)\n    }\n}\n\nexport interface UIOptions {\n    /** The preferred UI width. */\n    width?: number\n    /** The preferred UI height. */\n    height?: number\n    /** The initial window position, defaults to top left. */\n    position?: \"center\" | \"top left\" | \"bottom left\" | \"top right\" | \"bottom right\"\n    /** Whether the UI is resizable. */\n    resizable?: true | false | \"width\" | \"height\"\n    /** Minimum UI width. */\n    minWidth?: number\n    /** Minimum UI height. */\n    minHeight?: number\n}\n\nexport type NotificationVariant = \"info\" | \"success\" | \"error\" | \"warning\"\n\nexport interface ClosePluginOptions {\n    variant?: NotificationVariant\n}\n\ninterface NotifyOptionsBase {\n    /** The Notification variant for styling of the notification. Defaults to \"info\" */\n    variant?: NotificationVariant\n    /* Visibility duration in milliseconds. Defaults to 3000ms */\n    durationMs?: number\n}\n\nexport interface NotifyOptions extends NotifyOptionsBase {\n    /** A button to be displayed on the notification */\n    button?: {\n        /** The text of the button */\n        text: string\n        /** Click handler when the button is pressed */\n        onClick: () => void\n    }\n    /** A function that is called when the notification disappears */\n    onDisappear?: VoidFunction\n}\n\nexport interface NotifyOptionsData extends NotifyOptionsBase {\n    buttonText?: string\n    notificationId: string\n}\n\nexport interface Notification {\n    close: () => Promise<void>\n}\n\nexport interface User {\n    name: string\n    id: string // FIXME: can we share this?\n}\n\ninterface AddComponentInstanceOptions {\n    /** The component module URL. Can be copied from the components panel. */\n    url: string\n    /** Optional component attributes. */\n    attributes?: Partial<EditableComponentInstanceNodeAttributes>\n}\n\ninterface AddDetachedComponentLayersOptions {\n    /** The component module URL. Can be copied from the components panel. */\n    url: string\n    /** Optional component attributes. */\n    attributes?: Partial<EditableComponentInstanceNodeAttributes>\n    /** Insert the layers as a layout block and match variants with breakpoints. */\n    layout?: boolean\n}\n\nexport interface FramerAPI {\n    /** Show the plugin UI. */\n    showUI: (options?: UIOptions) => Promise<void>\n    /** Hide the plugin window, without stopping the plugin. */\n    hideUI: () => Promise<void>\n    /** Stop the plugin. */\n    closePlugin(message?: string, options?: ClosePluginOptions): Promise<void>\n\n    /** Get the current mode. A plugin can launch in a special mode where only a subset of the API is allowed. */\n    readonly mode: Mode\n    /** Get the current user info. */\n    getCurrentUser(): Promise<User>\n\n    /** Get the current selection. */\n    getSelection: () => Promise<CanvasNode[]>\n    /** Set the current selection. */\n    setSelection: (nodeIds: NodeId | Iterable<NodeId>) => Promise<void>\n    /** Subscribe to selection changes. */\n    subscribeToSelection: (selectionUpdate: (nodes: CanvasNode[]) => void) => Unsubscribe\n\n    /** Get the root of the current canvas. */\n    getCanvasRoot: () => Promise<CanvasRootNode>\n    /** Subscribe to canvas root changes */\n    subscribeToCanvasRoot: (rootUpdate: (root: CanvasRootNode) => void) => Unsubscribe\n\n    /** Get the current publish info. */\n    getPublishInfo: () => Promise<PublishInfo>\n    /** Subscribe to publish info changes. */\n    subscribeToPublishInfo: (publishInfoUpdate: (info: PublishInfo) => void) => Unsubscribe\n\n    /** Create a new node on the canvas. */\n    createFrameNode(attributes: Partial<EditableFrameNodeAttributes>, parentId?: NodeId): Promise<FrameNode | null>\n\n    /** Remove a node from the canvas. */\n    removeNode: (nodeId: NodeId) => Promise<void>\n    /** Clone a node. */\n    cloneNode: (nodeId: NodeId) => Promise<AnyNode | null>\n    /** Get a node by its id. */\n    getNode: (nodeId: NodeId) => Promise<AnyNode | null>\n    /** Get the parent of a node. */\n    getParent: (nodeId: NodeId) => Promise<AnyNode | null>\n    /** Get the children of a node. */\n    getChildren: (nodeId: NodeId) => Promise<AnyNode[]>\n    /** Get the rect of a node */\n    getRect: (nodeId: NodeId) => Promise<Rect | null>\n    /** Set the attributes of a node. */\n    setAttributes: (nodeId: NodeId, attributes: Partial<AnyEditableAttributes>) => Promise<AnyNode | null>\n    /** Set the parent of a node. */\n    setParent: (nodeId: NodeId, parentId: NodeId, index?: number) => Promise<void>\n\n    /** Get all nodes of a certain class. */\n    getNodesWithType(type: \"FrameNode\"): Promise<FrameNode[]>\n    getNodesWithType(type: \"TextNode\"): Promise<TextNode[]>\n    getNodesWithType(type: \"SVGNode\"): Promise<SVGNode[]>\n    getNodesWithType(type: \"ComponentInstanceNode\"): Promise<ComponentInstanceNode[]>\n    getNodesWithType(type: \"WebPageNode\"): Promise<WebPageNode[]>\n    getNodesWithType(type: \"ComponentNode\"): Promise<ComponentNode[]>\n    getNodesWithType(type: KnownNodeClass): Promise<AnyNode[]>\n    /** Get all nodes with a certain attribute. */\n    getNodesWithAttribute<T extends NodeAttributeKey, Node = NodeWithAttribute<T>>(attribute: T): Promise<Node[]>\n    /** Get all nodes with a certain attribute which value is set. */\n    getNodesWithAttributeSet<T extends NodeAttributeKey, Node = NodeWithAttribute<T>>(attribute: T): Promise<Node[]>\n\n    /** Pans and zooms the viewport to center a single or group of nodes. */\n    zoomIntoView: (nodeIds: NodeId | Iterable<NodeId>, options?: ZoomIntoViewOptions) => Promise<void>\n\n    /** Upload a